{
  "name": "purrfect-hub",
  "version": "4.0.0",
  "description": "Instagram for cats — Cloudflare Workers + D1 + R2",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",

    "db:create": "wrangler d1 create cats_db",
    "db:migrate": "wrangler d1 execute cats_db --file=./src/db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute cats_db --file=./src/db/schema.sql --remote",

    "db:migrate:v4": "wrangler d1 execute cats_db --file=./src/db/migration-v4-clean.sql",
    "db:migrate:v4:prod": "wrangler d1 execute cats_db --file=./src/db/migration-v4-clean.sql --remote",

    "r2:create": "wrangler r2 bucket create cats-bucket",

    "sync": "node scripts/sync.js all",
    "sync:facts": "node scripts/sync.js facts",
    "sync:facts:prod": "node scripts/sync.js facts --remote",

    "logs": "wrangler tail",
    "clean": "rm -rf dist .wrangler"
  },
  "keywords": ["cats", "cloudflare", "workers", "d1", "r2"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.47.0"
  },
  "dependencies": {}
}